@inherits LayoutComponentBase

@using WebUI.Components.Layout

<div class="page">

    <div class="sidebar">
        <NavMenu />
    </div>

    <main>

        <div class="top-row px-4">

            <div style="
                width:100%;
                display:flex;
                justify-content:flex-end;
                align-items:center;
                padding:10px">

                <TenantSelector />

            </div>

        </div>

        <article class="content px-4">
            @Body
        </article>

    </main>

</div>

<div id="blazor-error-ui" data-nosnippet>

    An unhandled error has occurred.

    <a href="." class="reload">
        Reload
    </a>

    <span class="dismiss">
        🗙
    </span>

</div>