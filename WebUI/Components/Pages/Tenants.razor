@page "/tenants"
@rendermode InteractiveServer

@using Application.Interfaces
@using Application.Services
@using Domain.Entities

@inject ITenantProvider TenantProvider
@inject FakeDataService FakeDataService


@inject ITenantProvider TenantProvider
@inject FakeDataService FakeDataService

<h3>Tenant Test</h3>

<button @onclick="SelectTenant1">
    Select Client A
</button>

<button @onclick="SelectTenant2">
    Select Client B
</button>

<hr />

<p>
    Current Tenant:
    @TenantProvider.TenantId
</p>

<hr />

@foreach (var item in records)
{
    <div>
        @item.Name - @item.Status
    </div>
}

@code
{
    private List<ClientRecord> records = new();

    private void SelectTenant1()
    {
        TenantProvider.TenantId =
            Guid.Parse("11111111-1111-1111-1111-111111111111");

        LoadData();
    }

    private void SelectTenant2()
    {
        TenantProvider.TenantId =
            Guid.Parse("22222222-2222-2222-2222-222222222222");

        LoadData();
    }

    private void LoadData()
    {
        records = FakeDataService.GetData();
    }
}